{
  "ConnectionStrings": {
    "AppIdentityConnection": "Host=localhost; Port=5432; Database=appidentity; Username=postgres; Password=root",
    "DatabaseConnection": "Host=localhost; Port=5432; Database=application; Username=postgres; Password=root; Include Error Detail=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GotenbergSharpClient": {
    "ServiceUrl": "http://localhost:3000",
    "HealthCheckUrl": "http://localhost:3000/health",
    "RetryPolicy": {
      "Enabled": true,
      "RetryCount": 4,
      "BackoffPower": 1.5,
      "LoggingEnabled": true
    }
  }
